# Local development only.
# Copy to `.env`, fill in real values, and keep that file untracked.
# In shared environments, inject the same variables via the process
# environment or a secret manager instead of committing secrets.

LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_API_KEY=sk-your-litellm-key
REASONING_MODEL=claude-opus-4.6-agent
SEARCH_MODEL=perplexity-sonar-pro-agent

# Optional direct-provider secrets for YAML references.
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# Optional: point to a non-default YAML config file.
# INQTRIX_CONFIG=inqtrix.yaml