# ============================================================
# Inqtrix starter environment template
# ============================================================
#
# Copy this file to .env for local development and keep .env untracked.
# Fill in only the sections that match the runtime path you actually use.
#
# This template stays focused on the provider, auth, endpoint, and model
# variables that are actually used by the default env mode and by the
# example scripts under examples/provider_stacks/ and examples/custom_providers/.
#
# Advanced tuning vars are intentionally omitted here for now.
# See README.md and src/inqtrix/settings.py for rounds, timeouts, cache,
# risk, and logging controls.

# ============================================================
# 1. Default env-based runtime
# ============================================================
#
# Used when you call ResearchAgent() without injecting explicit providers,
# or when the server runs in env-only mode.
#
# In this path, settings.py + providers/__init__.py auto-create:
# - LiteLLM for reasoning, classify, summarize, and evaluate
# - PerplexitySearch for web search
#
# Both providers share the same LiteLLM or OpenAI-compatible endpoint and
# the same key. Search therefore uses LITELLM_BASE_URL + LITELLM_API_KEY
# here, not a direct PERPLEXITY_API_KEY.

# Shared LiteLLM or OpenAI-compatible proxy endpoint.
# Example 1 uses http://localhost:4000/v1.
LITELLM_BASE_URL=http://localhost:4000/v1

# Shared key for BOTH LiteLLM reasoning calls and PerplexitySearch when the
# default env mode routes everything through the same proxy.
LITELLM_API_KEY=sk-your-litellm-key

# Optional model overrides.
#
# All variables in this block are optional because ModelSettings in
# src/inqtrix/settings.py already defines defaults:
# - REASONING_MODEL defaults to claude-opus-4.6-agent
# - SEARCH_MODEL defaults to perplexity-sonar-pro-agent
# - CLASSIFY_MODEL, SUMMARIZE_MODEL, and EVALUATE_MODEL default to empty
#   and then fall back to REASONING_MODEL at runtime
#
# Leave this whole block commented out if you want the built-in model mix.
# Define one or more of these vars only if you want to serve Inqtrix with a
# different setup, for example when:
# - your LiteLLM or OpenAI-compatible proxy exposes different model aliases
# - you want cheaper classify, summarize, or evaluate roles in server mode
# - you map roles to separate Azure or LiteLLM deployments
# - you want to benchmark or A/B test a different reasoning/search stack

# Main reasoning model used for planning, synthesis, and as the fallback
# for unset role-specific overrides.
# REASONING_MODEL=claude-opus-4.6-agent

# Search model used by PerplexitySearch in env mode.
# REASONING_MODEL and SEARCH_MODEL are independent on purpose.
# SEARCH_MODEL=perplexity-sonar-pro-agent

# Optional per-role override for question classification.
# Unset or empty means: use REASONING_MODEL.
# CLASSIFY_MODEL=your-classify-model

# Optional per-role override for parallel summarization and claim extraction.
# Unset or empty means: use REASONING_MODEL.
# SUMMARIZE_MODEL=your-summarize-model

# Optional per-role override for evidence evaluation.
# Unset or empty means: use REASONING_MODEL.
# EVALUATE_MODEL=your-evaluate-model

# ============================================================
# 2. Direct provider credentials for explicit examples
# ============================================================
#
# These vars are for the explicit-provider scripts, not for the env-only
# auto-create path above.
#
# Provider stack examples:
# - examples/provider_stacks/anthropic_perplexity.py
# - examples/provider_stacks/bedrock_perplexity.py
# - examples/provider_stacks/azure_openai_perplexity.py

# Direct Anthropic API key for AnthropicLLM.
# Anthropic is an LLM provider only. Search still needs a separate provider.
ANTHROPIC_API_KEY=

# Direct Perplexity Sonar API key for examples that call Perplexity without a
# LiteLLM proxy. Keep this defined only once.
PERPLEXITY_API_KEY=

# Optional AWS named profile for Bedrock example 3.
# Leave empty to use the default AWS credential chain/profile.
AWS_PROFILE=

# Optional AWS region for Bedrock example 3.
# The example defaults to eu-central-1 if this is empty.
AWS_REGION=eu-central-1

# ============================================================
# 3. Azure OpenAI reasoning provider
# ============================================================
#
# Used by the Azure examples for reasoning/model calls via AzureOpenAILLM.
#
# Important caveats:
# - AZURE_OPENAI_ENDPOINT must be the Azure OpenAI resource root.
# - Do NOT add /openai/v1 here; the provider appends /openai/v1 internally.
# - AZURE_OPENAI_DEPLOYMENT_NAME must be the deployment name, not the base
#   model name such as gpt-4o.

# Azure OpenAI API key for the default API-key auth path in the Azure examples.
AZURE_OPENAI_API_KEY=

# Azure OpenAI resource root, for example:
# https://your-resource.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/

# Azure deployment name used by AzureOpenAILLM.
# This must be the deployment name configured in Azure.
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name

# Optional cheaper Azure deployment for summarize helper calls.
# Leave empty to keep summarize work on the main deployment.
AZURE_OPENAI_SUMMARIZE_DEPLOYMENT_NAME=

# Optional Entra ID / service principal auth values used by the commented
# Azure example paths instead of API-key auth.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ============================================================
# 4. Azure AI Foundry search providers
# ============================================================
#
# Shared project-scoped endpoint used by both Foundry search paths below.
# It should look like:
# https://your-project.services.ai.azure.com/api/projects/your-project
AZURE_AI_PROJECT_ENDPOINT=https://YOUR_PROJECT.services.ai.azure.com/api/projects/YOUR_PROJECT

# ------------------------------------------------------------
# 4A. Classic Bing agent path
# ------------------------------------------------------------
#
# Used by:
# - examples/provider_stacks/azure_openai_bing.py
# - examples/provider_stacks/azure_smoke_tests/test_bing_search.py
#
# This path reuses a pre-created Azure AI Foundry agent with Bing Grounding.
# BING_AGENT_ID is the runtime identifier for that existing agent.
# AZURE_AI_PROJECT_API_KEY is NOT the normal auth path for this classic Bing
# agent example.

# Existing Bing Grounding agent ID for the classic Bing path.
BING_AGENT_ID=

# Only needed if you use AzureFoundryBingSearch.create_agent() once to create
# the Bing agent. Not needed for normal runs when BING_AGENT_ID already exists.
BING_PROJECT_CONNECTION_ID=/subscriptions/.../connections/your-bing-connection

# ------------------------------------------------------------
# 4B. Foundry Web Search path
# ------------------------------------------------------------
#
# Used by:
# - examples/provider_stacks/azure_foundry_web_search.py
# - examples/provider_stacks/azure_smoke_tests/test_foundry_web_search.py
#
# This path uses the project-scoped Responses API with agent_reference.
# WEB_SEARCH_AGENT_NAME identifies the existing Web Search agent by name.
# WEB_SEARCH_AGENT_VERSION is optional; leave empty for the default/latest.

# Existing Web Search agent name for the Foundry Responses API path.
WEB_SEARCH_AGENT_NAME=

# Optional pinned agent version. Leave empty for the default/latest version.
WEB_SEARCH_AGENT_VERSION=

# Optional project API key for the Foundry Web Search path only.
# This is used by AzureFoundryWebSearch and is not required for the classic
# Bing agent path above.
AZURE_AI_PROJECT_API_KEY=

# ============================================================
# 5. Optional YAML/config reference variables
# ============================================================
#
# These are mainly for inqtrix.yaml and inqtrix.yaml.example placeholders,
# not for the default env-only runtime in section 1.

# Optional direct OpenAI key used by YAML ${OPENAI_API_KEY} placeholders.
OPENAI_API_KEY=

# Optional custom path to a YAML config file.
# Used by load_config() and server YAML mode.
INQTRIX_CONFIG=


# ============================================================
# 6. Streamlit webapp.py wiring
# ============================================================
#
# Consumed exclusively by `webapp.py` via `inqtrix_webapp.client`.
# The UI is a pure HTTP consumer and never imports the `inqtrix`
# package, so these two variables are the entire surface for
# pointing the UI at a running Inqtrix HTTP server.

# Base URL of the Inqtrix HTTP server (single-stack or multi-stack).
# Defaults to http://localhost:5100 when unset.
INQTRIX_WEBAPP_BASE_URL=http://localhost:5100

# Optional Bearer token sent as `Authorization: Bearer <key>` when
# the server was started with INQTRIX_SERVER_API_KEY. Leave empty
# when the API-key gate is off.
INQTRIX_WEBAPP_API_KEY=